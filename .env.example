# ─────────────────────────────────────────────────────────────────────────────
# POV3 Query Auto-Optimization Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Snowflake Connection ──────────────────────────────────────────────────────
# Account identifier: found in Snowflake UI → Admin → Accounts
# Format: <orgname>-<account_name> OR <account_locator>.<region>
SNOWFLAKE_ACCOUNT=xy12345.us-east-1

# Authentication
SNOWFLAKE_USER=POV3_SERVICE_USER
SNOWFLAKE_PASSWORD=your_password_here

# Target environment
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# Optional: dedicated XS warehouse for clean BYTES_SCANNED measurements.
# When set, the ValidationAgent suspends this warehouse before each optimized
# query run (clearing the local SSD disk cache) then resumes it cold.
# This eliminates warm-cache inflation and gives reproducible scan metrics.
# One-time Snowflake setup (requires SYSADMIN or similar role):
#   CREATE WAREHOUSE OPTIMIZER_BENCH_WH WAREHOUSE_SIZE='X-SMALL' AUTO_SUSPEND=60
#     AUTO_RESUME=TRUE INITIALLY_SUSPENDED=TRUE;
#   GRANT USAGE, OPERATE ON WAREHOUSE OPTIMIZER_BENCH_WH TO ROLE POV3_AGENT_ROLE;
SNOWFLAKE_BENCHMARK_WAREHOUSE=
SNOWFLAKE_DATABASE=ANALYTICS_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=POV3_AGENT_ROLE

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable real Snowflake queries in AnalysisAgent.
# When "false" or unset, the agent uses mock/regex fallback logic.
SNOWFLAKE_ENABLED=false

# Set to "true" to enable AWS Bedrock LLM in OptimizationAgent.
# When "false" the agent uses deterministic rewrite rules (MVP mode).
BEDROCK_ENABLED=false

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Source: AWS Console → IAM → Users → pov3-bedrock-agent → Security credentials
# Create an access key under the "Application running outside AWS" use case.
# WARNING: Never commit real credentials to Git.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# AWS region where Bedrock model access was granted.
# Recommended: us-east-1 (N. Virginia) — widest model availability.
# Asia-Pacific alternative: ap-southeast-1 (Singapore)
AWS_REGION=us-east-1

# ── Bedrock Model Configuration ───────────────────────────────────────────────
# Primary optimization LLM (complex SQL rewriting + chain-of-thought)
# Source: AWS Console → Bedrock → Model access → copy model ID
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Fast pre-screening LLM (semantic equivalence checking, quick classification)
BEDROCK_SCREENER_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Embedding model for RAG knowledge base ingestion
# Used by Bedrock Knowledge Bases to vectorize optimization reports
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Maximum tokens for optimization LLM responses
BEDROCK_MAX_TOKENS=4096

# ── RAG Knowledge Base (Phase 2) ──────────────────────────────────────────────
# Bedrock Knowledge Base ID — created in AWS Console → Bedrock → Knowledge Bases
# Leave blank until Phase 2 setup is complete.
# Format: alphanumeric string, e.g. ABCD1234EF
BEDROCK_KB_ID=

# S3 bucket for storing optimization reports (source data ingested into the KB)
# Create this bucket in S3 before running Phase 2.
# Naming convention: must be globally unique, lowercase, no underscores.
S3_BUCKET_NAME=pov3-optimization-reports

# S3 key prefix for optimization reports
S3_REPORTS_PREFIX=reports/

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── LangSmith Observability (Cloud Tier) ──────────────────────────────────────
# Sign up at https://smith.langchain.com and create an API key.
# This enables chain-of-thought tracing, agent reasoning logs, and confidence
# score monitoring across all pipeline agents.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pov3-query-optimizer
LANGSMITH_TRACING_V2=false

# ── NATS JetStream Messaging (POV4 → POV3 inter-project communication) ───────
# NATS server URL. Default: nats://localhost:4222
# For clusters: nats://n1:4222,nats://n2:4222
#
# IMPORTANT: The NATS server must be started with JetStream enabled:
#   docker run -d --name nats-js -p 4222:4222 nats:latest -js
#
# Or in a NATS config file:
#   jetstream: { store_dir: "/data" }
NATS_URL=nats://localhost:4222

# Subject that POV4 publishes optimization alerts to.
# This subject must fall within the subjects captured by NATS_STREAM_NAME.
NATS_SUBJECT=pov4.alerts.optimization

# Queue group for load-balanced consumption across multiple POV3 instances.
# JetStream guarantees each message is delivered to exactly one member.
NATS_QUEUE_GROUP=pov3-workers

# Set to "true" to start the JetStream subscriber alongside the FastAPI server.
NATS_ENABLED=false

# ── JetStream-specific settings ───────────────────────────────────────────────
# Name of the durable JetStream stream that persists POV4 alerts.
# Created automatically on first startup (idempotent).
# Messages in this stream survive POV3 restarts and crashes.
NATS_STREAM_NAME=pov4-alerts

# Durable consumer name for the push subscriber.
# IMPORTANT: In nats-py, when using queue subscriptions, the consumer name
# MUST equal the queue group name (NATS_QUEUE_GROUP). They must be the same.
NATS_CONSUMER_NAME=pov3-workers

# Seconds before an unacknowledged message is redelivered.
# Set this comfortably above your worst-case pipeline execution time
# (e.g. if the LLM + Snowflake round-trip can take 25s, use 60).
NATS_ACK_WAIT_SECONDS=30

# ── Target Repository (PR Agent) ─────────────────────────────────────────────
# The application repo the PR Agent will create Draft PRs in.
# Must be in "owner/repo" format.
TARGET_REPO=SurajCSENITS/demo-tpch-app

# GitHub Personal Access Token with `repo` scope on the target repo.
# Generate at: https://github.com/settings/tokens
TARGET_REPO_TOKEN=ghp_your_personal_access_token_here

# Branch to base new optimisation PRs on.
TARGET_REPO_DEFAULT_BRANCH=main
